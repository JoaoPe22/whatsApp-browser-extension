{
  "manifest_version": 3,
  "name": "WhatsApp Browser Extension",
  "version": "0.1.0",
  "description": "Base extension for WhatsApp Web automation studies.",
  "permissions": ["storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "WhatsApp Helper",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
